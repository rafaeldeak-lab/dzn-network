# App URLs
# DZN_APP_URL must point to production, not a preview deploy.
DZN_APP_URL=https://dzn-network.pages.dev
NEXT_PUBLIC_APP_URL=https://dzn-network.pages.dev

# Automation cron security
# Set DZN_CRON_SECRET in BOTH Cloudflare Pages and the Cloudflare Worker.
# The two values must match exactly. Do not expose this value in client code.
DZN_CRON_SECRET=replace-with-a-long-random-secret

# Stripe runtime secrets. Never commit real values.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe subscription price IDs. Runtime code prefers these server-side names.
STRIPE_PRICE_STARTER=price_1TY4c6JPrnZ0cnkH7207aAi4
STRIPE_PRICE_PRO=price_1TY4dDJPrnZ0cnkH4OhfEHmW
STRIPE_PRICE_NETWORK=price_1TY4diJPrnZ0cnkHoqKk4pKc
STRIPE_PRICE_PARTNER=price_1TY4eRJPrnZ0cnkHtGLvMetv

# Legacy/public price ID aliases are still accepted during rollout.
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_1TY4c6JPrnZ0cnkH7207aAi4
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_1TY4dDJPrnZ0cnkH4OhfEHmW
NEXT_PUBLIC_STRIPE_NETWORK_PRICE_ID=price_1TY4diJPrnZ0cnkHoqKk4pKc
NEXT_PUBLIC_STRIPE_PARTNER_PRICE_ID=price_1TY4eRJPrnZ0cnkHtGLvMetv

# Admin and Discord automation
DZN_ADMIN_DISCORD_IDS=comma-separated-discord-user-ids
DISCORD_BOT_TOKEN=bot-token-goes-in-cloudflare-secrets-only
