{
  "name": "dzn-network",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "npm run test:adm-parser && npm run test:discord-guilds && npm run test:server-metadata && npm run test:public-leaderboards",
    "test:adm-parser": "tsx scripts/test-adm-parser.ts",
    "test:discord-guilds": "tsx scripts/test-discord-guilds.ts",
    "test:server-metadata": "tsx scripts/test-server-metadata.ts",
    "test:public-leaderboards": "tsx scripts/test-public-leaderboards.ts",
    "backfill:adm:once": "tsx scripts/one-time-adm-backfill.ts",
    "repair:readded-server": "tsx scripts/repair-readded-server.ts",
    "audit:linked-servers": "tsx scripts/audit-linked-servers.ts",
    "db:migrate:local": "wrangler d1 migrations apply dzn_network_db --local",
    "db:migrate:remote": "wrangler d1 migrations apply dzn_network_db --remote",
    "worker:adm-sync:dev": "wrangler dev --config wrangler.adm-sync.toml --test-scheduled",
    "worker:adm-sync:dry-run": "wrangler deploy --config wrangler.adm-sync.toml --dry-run",
    "worker:adm-sync:deploy": "wrangler deploy --config wrangler.adm-sync.toml"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.0",
    "typescript": "^5",
    "wrangler": "^4.90.1"
  }
}
