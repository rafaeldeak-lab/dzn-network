{
  "mode": "pr_only",
  "scope": "adm_tracking_only",
  "allowDirectMainPush": false,
  "allowAutoMergeLowRisk": false,
  "allowCodexSafeFixes": true,
  "allowCodexHighRiskFixes": false,
  "maxFixAttemptsPerRun": 3,
  "maxRuntimeMinutes": 45,
  "maxChangedFilesPerRun": 20,
  "maxTokensHint": "bounded",
  "productionUrl": "https://dzn-network.pages.dev",
  "deployPreviewRequired": true,
  "watchAdmCycles": true,
  "watchMinutesAfterDeploy": 90,
  "admOnly": {
    "enabled": true,
    "allowedSystems": [
      "adm-sync-worker",
      "nitrado-file-read",
      "adm-diagnostics",
      "adm-import-jobs",
      "adm-sync-state",
      "dashboard-sync-health",
      "adm-production-smoke",
      "adm-cycle-watch",
      "manual-adm-import-support-only"
    ],
    "blockedSystems": [
      "billing",
      "stripe",
      "discord-oauth",
      "sessions",
      "subscriptions",
      "account-management",
      "server-owner-private-settings",
      "events-tournaments-unrelated",
      "public-marketing-unrelated",
      "payment-plans",
      "role-permissions-unrelated"
    ]
  },
  "codex": {
    "enabled": true,
    "issueLabelsRequired": ["autodev", "adm-tracking", "autodev-safe-fix", "low-risk"],
    "issueLabelsBlocked": [
      "high-risk",
      "needs-human-review",
      "security",
      "billing",
      "auth",
      "stripe",
      "discord-oauth",
      "database-destructive",
      "account-management",
      "subscriptions",
      "server-settings",
      "events-unrelated",
      "worker-cron-high-risk",
      "token-encryption"
    ],
    "openPullRequestOnly": true,
    "directPushToMain": false,
    "autoMerge": false
  },
  "riskGates": {
    "blockAuthChanges": true,
    "blockBillingChanges": true,
    "blockDestructiveMigrations": true,
    "blockSecretChanges": true,
    "blockAdmParserRewrite": true,
    "blockWorkerCronChanges": true
  }
}
